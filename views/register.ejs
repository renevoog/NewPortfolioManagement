<%- include('partials/header') %>

    <div class="auth-wrapper">
      <div class="auth-card">
        <h1>Register</h1>

        <% if (typeof errors !== 'undefined' && errors && errors.length) { %>
          <% errors.forEach(function(e) { %>
            <div class="flash-msg flash-error"><%= e.msg %></div>
          <% }); %>
        <% } %>

        <form action="/register" method="POST">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" value="<%= typeof name !== 'undefined' ? name : '' %>" required autofocus />

          <label for="email">Email</label>
          <input id="email" name="email" type="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <label for="password2">Confirm Password</label>
          <input id="password2" name="password2" type="password" required />

          <button type="submit" class="btn-primary">Register</button>
        </form>

        <a class="auth-link" href="/login">Already have an account? Sign in</a>
      </div>
    </div>

<%- include('partials/footer') %>
