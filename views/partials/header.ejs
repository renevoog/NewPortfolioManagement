<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Portfolio Manager' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Exo:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="/css/dashboard.css" rel="stylesheet" />
  </head>
  <body>
    <nav class="navbar">
      <div class="container-lg d-flex justify-content-between align-items-center">
        <a class="navbar-brand" href="/home">
          <i class="bi bi-bar-chart-line-fill"></i> Portfolio Manager
        </a>
        <% if (typeof userName !== 'undefined' && userName) { %>
          <div class="navbar-user">
            <span class="navbar-user-name"><%= userName %></span>
            <a href="/logout" class="btn-logout" title="Logout">
              <i class="bi bi-box-arrow-right"></i>
            </a>
          </div>
        <% } %>
      </div>
    </nav>
    <main class="container-lg">
